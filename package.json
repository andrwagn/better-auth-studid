{
  "name": "@studid/better-auth-studid",
  "version": "0.1.5",
  "description": "Sign in with your university — Better Auth plugin for Studid (SAML academic verification)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "bun run build",
    "lint": "tsc --noEmit",
    "lint:types": "tsc --noEmit"
  },
  "peerDependencies": {
    "better-auth": "^1.5.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "better-auth": "^1.5.4",
    "@types/node": "^25.7.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "studid",
    "saml",
    "university",
    "academic",
    "authentication",
    "edugain"
  ],
  "author": "andrwagn",
  "license": "MIT",
  "homepage": "https://better-auth-demo.studid.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrwagn/better-auth-studid.git"
  },
  "bugs": {
    "url": "https://github.com/andrwagn/better-auth-studid/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
